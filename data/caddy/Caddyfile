<<binding>> {
	@frontend {
		method GET
		path *
	}

	@backend {
		method GET PUT POST PATCH DELETE
		path /api/*
	}

	@beta-backend {
		method GET PUT POST PATCH DELETE
		path /kong/*
	}

	@files {
		method GET
		path /files/*
	}

	handle @frontend {
		reverse_proxy frontend:80 {
			header_down -Server
		}
	}

	handle @backend {
		uri strip_prefix /api
		reverse_proxy api-gateway:8090 {
			header_down -Server
		}
	}

	handle @beta-backend {
		uri strip_prefix /kong
		reverse_proxy kong-gateway:8000 {
			header_down -Server
		}
	}

	handle @files {
		uri strip_prefix /files
		root * /files
		file_server
	}
}
