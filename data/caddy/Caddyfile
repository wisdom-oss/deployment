<<binding>> {

  @frontend {
    method GET
    path *
  }

  @backend {
    method GET PUT POST PATCH DELETE
    path /api/*
  }

  handle @frontend {
    reverse_proxy frontend:80 {
      header_down -Server
    }
  }

  handle @backend {
    uri strip_prefix /api
    reverse_proxy api-gateway:8090 {
      header_down -Server
    }
  }


}